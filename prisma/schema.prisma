generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum CycleStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum CycleType {
  PERFORMANCE
  PEER
  FEEDBACK_360
  MANAGER
  SELF
  PROBATION
  PROMOTION
  CONTINUOUS
}

enum FeedbackStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  PUBLISHED
}

enum QuestionType {
  TEXT
  LONG_TEXT
  RATING_1_5
  RATING_1_10
  EMOJI_SCALE
  MULTIPLE_CHOICE
  MULTI_SELECT
  BOOLEAN
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  UNREAD
  READ
  SENT
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  START
  CLOSE
  ARCHIVE
  SUBMIT
  APPROVE
  PUBLISH
  PERMISSION_CHANGE
  LOGIN
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  emailVerified      DateTime?
  name               String
  title              String?
  image              String?
  passwordHash       String?
  status             UserStatus          @default(ACTIVE)
  teamId             String?
  managerId          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  team               Team?               @relation(fields: [teamId], references: [id], onDelete: SetNull)
  manager            User?               @relation("ManagerReports", fields: [managerId], references: [id], onDelete: SetNull)
  reports            User[]              @relation("ManagerReports")
  roles              UserRole[]
  accounts           Account[]
  sessions           Session[]
  requestedFeedback  Feedback[]          @relation("FeedbackRequester")
  receivedFeedback   Feedback[]          @relation("FeedbackSubject")
  authoredFeedback   Feedback[]          @relation("FeedbackAuthor")
  approvedFeedback   Feedback[]          @relation("FeedbackApprover")
  answers            Answer[]
  comments           Comment[]
  notifications      Notification[]
  attachments        Attachment[]
  auditLogs          AuditLog[]          @relation("AuditActor")
  mentionedComments  CommentMention[]

  @@index([teamId])
  @@index([managerId])
  @@index([status])
  @@index([name])
}

model Team {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  productId   String?
  parentId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  product     Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  parent      Team?         @relation("TeamHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Team[]        @relation("TeamHierarchy")
  users       User[]
  cycles      ReviewCycle[]

  @@index([productId])
  @@index([parentId])
}

model Product {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  ownerId     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  teams       Team[]
  cycles      ReviewCycle[]

  @@index([name])
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model FeedbackTemplate {
  id          String        @id @default(cuid())
  name        String
  description String?
  builtIn     Boolean       @default(false)
  active      Boolean       @default(true)
  version     Int           @default(1)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  sections    Section[]
  cycles      ReviewCycle[]

  @@unique([name, version])
  @@index([active, builtIn])
}

model Section {
  id          String           @id @default(cuid())
  templateId  String
  title       String
  description String?
  order       Int
  template    FeedbackTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions   Question[]

  @@unique([templateId, order])
  @@index([templateId])
}

model Question {
  id          String       @id @default(cuid())
  sectionId   String
  prompt      String
  helpText    String?
  type        QuestionType
  required    Boolean      @default(true)
  options     Json?
  order       Int
  weight      Decimal      @default(1.0) @db.Decimal(5, 2)
  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers     Answer[]

  @@unique([sectionId, order])
  @@index([sectionId])
  @@index([type])
}

model ReviewCycle {
  id                 String             @id @default(cuid())
  name               String
  description        String?
  type               CycleType
  status             CycleStatus        @default(DRAFT)
  startsAt           DateTime?
  endsAt             DateTime?
  templateId         String
  productId          String?
  teamId             String?
  workflowConfig     Json
  createdById        String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  template           FeedbackTemplate   @relation(fields: [templateId], references: [id], onDelete: Restrict)
  product            Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  team               Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  feedback           Feedback[]

  @@index([status, startsAt, endsAt])
  @@index([templateId])
  @@index([productId])
  @@index([teamId])
  @@index([createdById])
}

model Feedback {
  id                  String          @id @default(cuid())
  cycleId             String
  requesterId         String
  subjectId           String
  authorId            String
  approverId          String?
  status              FeedbackStatus  @default(DRAFT)
  progress            Int             @default(0)
  templateSnapshot    Json
  submittedAt         DateTime?
  approvedAt          DateTime?
  publishedAt         DateTime?
  lastAutosavedAt     DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  cycle               ReviewCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  requester           User            @relation("FeedbackRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  subject             User            @relation("FeedbackSubject", fields: [subjectId], references: [id], onDelete: Restrict)
  author              User            @relation("FeedbackAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  approver            User?           @relation("FeedbackApprover", fields: [approverId], references: [id], onDelete: SetNull)
  answers             Answer[]
  comments            Comment[]
  attachments         Attachment[]

  @@index([cycleId, status])
  @@index([subjectId, status])
  @@index([authorId, status])
  @@index([requesterId])
  @@index([updatedAt])
}

model Answer {
  id          String    @id @default(cuid())
  feedbackId  String
  questionId  String
  authorId    String
  value       Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  feedback    Feedback  @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Restrict)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@unique([feedbackId, questionId])
  @@index([questionId])
  @@index([authorId])
}

model Comment {
  id          String           @id @default(cuid())
  feedbackId  String
  authorId    String
  body        String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  feedback    Feedback         @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  author      User             @relation(fields: [authorId], references: [id], onDelete: Restrict)
  mentions    CommentMention[]

  @@index([feedbackId, createdAt])
  @@index([authorId])
}

model CommentMention {
  commentId String
  userId    String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(UNREAD)
  type        String
  title       String
  body        String
  href        String?
  metadata    Json?
  createdAt   DateTime            @default(now())
  readAt      DateTime?
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([type])
}

model Attachment {
  id          String    @id @default(cuid())
  feedbackId  String?
  uploadedById String
  fileName    String
  mimeType    String
  byteSize    Int
  storageKey  String
  url         String?
  createdAt   DateTime  @default(now())
  feedback    Feedback? @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  uploadedBy  User      @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([feedbackId])
  @@index([uploadedById])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String
  summary    String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
